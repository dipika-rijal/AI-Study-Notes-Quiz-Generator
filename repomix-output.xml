/* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
   🌍 BASE
   ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */

*, *::before, *::after { box-sizing: border-box; }

html {
  transition: background-color 0.35s ease, color 0.35s ease;
}

body {
  background: var(--theme-bg-primary);
  color: var(--theme-text-primary);
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  -webkit-font-smoothing: antialiased;
  overflow-x: hidden;
  transition: background-color 0.35s ease, color 0.35s ease;
}

/* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
   🪟 GLASS / SURFACE
   ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */

.glass {
  background: var(--theme-surface);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid var(--theme-glass-border);
  transition: background 0.3s ease, border-color 0.3s ease;
}
.glass:hover {
  background: var(--theme-surface-hover);
}

/* Elevated card (has bg + border + shadow) */
.surface-card {
  background: var(--theme-bg-secondary);
  border: 1px solid var(--theme-glass-border);
  border-radius: 20px;
  box-shadow: var(--theme-card-shadow);
  transition: background 0.3s ease, border-color 0.3s ease,
              transform 0.3s cubic-bezier(0.16,1,0.3,1),
              box-shadow 0.3s cubic-bezier(0.16,1,0.3,1);
  will-change: transform;
}
.surface-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--theme-card-hover-shadow);
  border-color: rgba(255,255,255,0.25);
}

/* Inner/deeper card */
.surface-card-inner {
  background: var(--theme-bg-tertiary);
  border: 1px solid var(--theme-glass-border);
  border-radius: 14px;
  transition: background 0.3s ease, border-color 0.3s ease;
}

/* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
   ✍️ TEXT
   ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */

.text-primary   { color: var(--theme-text-primary);   }
.text-secondary { color: var(--theme-text-secondary); }
.text-muted     { color: var(--theme-text-muted);     }

/* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
   ✨ SHIMMER TEXT
   ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */

@keyframes shimmer-text {
  0%   { background-position: -300% center; }
  100% { background-position:  300% center; }
}
.shimmer-text {
  background: linear-gradient(90deg, #ececec, #10a37f, #ececec);
  background-size: 300% auto;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: shimmer-text 6s linear infinite;
}
html[data-theme="light"] .shimmer-text {
  background: linear-gradient(90deg, #6d28d9, #0891b2, #db2777, #d97706, #6d28d9);
  background-size: 300% auto;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
   🔥 ANIMATIONS
   ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */

@keyframes glow-pulse {
  0%,100% { opacity:0.3; transform:scale(1); }
  50%      { opacity:0.9; transform:scale(1.08); }
}
.glow-pulse { animation: glow-pulse 3s ease-in-out infinite; }

@keyframes float-slow {
  0%,100% { transform:translateY(0) rotate(0deg); }
  50%      { transform:translateY(-20px) rotate(3deg); }
}
.float-slow { animation: float-slow 7s ease-in-out infinite; }

@keyframes float-medium {
  0%,100% { transform:translateY(0); }
  50%      { transform:translateY(-12px); }
}
.float-medium { animation: float-medium 4s ease-in-out infinite; }

@keyframes breathe {
  0%,100% { transform:scale(1);    opacity:0.5; }
  50%      { transform:scale(1.15); opacity:1; }
}
.breathe { animation: breathe 4s ease-in-out infinite; }

@keyframes slide-up {
  from { opacity:0; transform:translateY(60px) scale(0.95); }
  to   { opacity:1; transform:translateY(0)    scale(1); }
}
.animate-slide-up { animation: slide-up 0.8s cubic-bezier(0.16,1,0.3,1) both; }

/* Hover utils */
.hover-lift {
  transition: transform 0.4s cubic-bezier(0.16,1,0.3,1),
              box-shadow 0.4s cubic-bezier(0.16,1,0.3,1);
  will-change: transform;
}
.hover-lift:hover {
  transform: translateY(-8px) scale(1.01);
  box-shadow: var(--theme-card-hover-shadow);
}
.hover-glow { transition: all 0.4s cubic-bezier(0.16,1,0.3,1); }
.hover-glow:hover {
  box-shadow: 0 0 40px rgba(255,255,255,0.1);
  border-color: rgba(255,255,255,0.25);
}

/* Scroll reveal */
.reveal {
  opacity:0;
  transform:translateY(40px);
  transition: opacity 1s cubic-bezier(0.16,1,0.3,1),
              transform 1s cubic-bezier(0.16,1,0.3,1);
}
.reveal.visible { opacity:1; transform:translateY(0); }

/* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
   🔘 FOCUS / A11Y
   ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */
:focus-visible {
  outline: 2px solid var(--theme-glow-purple);
  outline-offset: 3px;
  border-radius: 6px;
}

/* Scrollbar */
::-webkit-scrollbar       { width:6px; }
::-webkit-scrollbar-track { background:var(--theme-bg-primary); }
::-webkit-scrollbar-thumb { background:var(--theme-glow-purple); border-radius:999px; }
::-webkit-scrollbar-thumb:hover { background:#c4b5fd; }
::selection { background:var(--theme-glow-purple); color:white; }

/* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
